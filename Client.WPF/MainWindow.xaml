<Window x:Class="EmpresaChat.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:cef="clr-namespace:CefSharp.Wpf;assembly=CefSharp.Wpf"
        Title="ChatAgenda — Cliente" Height="700" Width="420"
        WindowStartupLocation="Manual"
        Background="#F8FAFC"
        Icon="app.ico">

    <Window.Resources>
        <SolidColorBrush x:Key="BgPrimary"     Color="#F8FAFC"/>
        <SolidColorBrush x:Key="BgCard"        Color="#FFFFFF"/>
        <SolidColorBrush x:Key="AccentBlue"    Color="#4F46E5"/>
        <SolidColorBrush x:Key="TextPrimary"   Color="#0F172A"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#64748B"/>
        <SolidColorBrush x:Key="Border"        Color="#E2E8F0"/>

        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background"      Value="#3B82F6"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2563EB"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══ HEADER ══ -->
        <Border Grid.Row="0" Background="#FFFFFF" Padding="12,8"
                BorderThickness="0,0,0,1" BorderBrush="#E2E8F0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="StatusText" Text="Conectando..." VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondary}" FontSize="11" FontFamily="Segoe UI" Visibility="Collapsed"/>
                </StackPanel>

                <Button Grid.Column="1" Content="⚙ Configuración" Style="{StaticResource BtnPrimary}"
                        Click="BtnChangeMode_Click" Padding="10,5" FontSize="11"
                        Background="#F1F5F9" Foreground="#334155"/>
            </Grid>
        </Border>

        <!-- ══ WEBVIEW (ocupa toda la ventana cuando conectado) ══ -->
        <cef:ChromiumWebBrowser Grid.Row="1" x:Name="WebView" Address="about:blank"/>

        <!-- ══ SETUP OVERLAY ══ -->
        <Grid Grid.Row="0" Grid.RowSpan="2" x:Name="SetupOverlay"
              Background="#F8FAFC" Panel.ZIndex="1000">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="320">

                <!-- Logo / título -->
                <TextBlock Text="💬" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="ChatAgenda" FontSize="32" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center"
                           FontFamily="Segoe UI" Margin="0,0,0,4"/>
                <TextBlock Text="Cliente de Mensajería Empresarial" FontSize="13"
                           Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center"
                           FontFamily="Segoe UI" Margin="0,0,0,32"/>

                <!-- Card de conexión -->
                <Border Background="{StaticResource BgCard}" CornerRadius="14"
                        BorderThickness="1" BorderBrush="{StaticResource Border}" Padding="24,20">
                    <StackPanel>
                        <TextBlock Text="Conectar al servidor" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}" FontFamily="Segoe UI" Margin="0,0,0,16"/>

                        <TextBlock Text="Dirección IP del servidor de la oficina:" FontSize="11"
                                   Foreground="{StaticResource TextSecondary}" FontFamily="Segoe UI" Margin="0,0,0,6"/>

                        <Border CornerRadius="8" BorderThickness="1" BorderBrush="#CBD5E1"
                                Background="#FFFFFF" Padding="1">
                            <TextBox x:Name="ClientIpInput"
                                     Text="http://192.168.1.100:5002"
                                     Padding="12,10" Background="Transparent"
                                     Foreground="#0F172A" BorderThickness="0"
                                     FontFamily="Consolas" FontSize="13"
                                     CaretBrush="White" SelectionBrush="#3B82F6"/>
                        </Border>

                        <TextBlock Text="Ejemplo: http://192.168.1.10:5002" FontSize="10"
                                   Foreground="#94A3B8" FontFamily="Segoe UI" Margin="4,5,0,16"/>

                        <Button Content="▶  Conectar" Style="{StaticResource BtnPrimary}"
                                Click="BtnConnect_Click" Height="42" FontSize="14"/>

                        <!-- Error message -->
                        <TextBlock x:Name="TxtError" Text="" FontSize="11"
                                   Foreground="#EF4444" FontFamily="Segoe UI"
                                   HorizontalAlignment="Center" Margin="0,10,0,0"
                                   TextWrapping="Wrap" Visibility="Collapsed"/>
                    </StackPanel>
                </Border>

                <TextBlock Text="Pide la dirección al administrador del servidor" FontSize="10"
                           Foreground="#94A3B8" HorizontalAlignment="Center"
                           FontFamily="Segoe UI" Margin="0,12,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>

<Window x:Class="ChatAgendaServer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ChatAgenda — Panel del Servidor"
        Width="480" Height="640"
        MinWidth="420" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        Background="#F8FAFC"
        ResizeMode="CanMinimize">

    <Window.Resources>
        <!-- Colores principales -->
        <SolidColorBrush x:Key="BgPrimary"     Color="#F8FAFC"/>
        <SolidColorBrush x:Key="BgCard"        Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BgCardHover"   Color="#F1F5F9"/>
        <SolidColorBrush x:Key="AccentGreen"   Color="#22C55E"/>
        <SolidColorBrush x:Key="AccentRed"     Color="#EF4444"/>
        <SolidColorBrush x:Key="AccentBlue"    Color="#3B82F6"/>
        <SolidColorBrush x:Key="AccentOrange"  Color="#F59E0B"/>
        <SolidColorBrush x:Key="TextPrimary"   Color="#0F172A"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#64748B"/>
        <SolidColorBrush x:Key="Border"        Color="#E2E8F0"/>

        <!-- Botón primario -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background"  Value="#3B82F6"/>
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Padding"     Value="16,9"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2563EB"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#334155"/>
                                <Setter Property="Foreground" Value="#64748B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botón de peligro -->
        <Style x:Key="BtnDanger" TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
            <Setter Property="Background" Value="#EF4444"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#DC2626"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Botón verde -->
        <Style x:Key="BtnSuccess" TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
            <Setter Property="Background" Value="#16A34A"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#15803D"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header -->
            <RowDefinition Height="*"/>      <!-- Content -->
            <RowDefinition Height="Auto"/>   <!-- Footer status -->
        </Grid.RowDefinitions>

        <!-- ═══════════════ HEADER ═══════════════ -->
        <Border Grid.Row="0" Background="#FFFFFF" Padding="24,18" BorderThickness="0,0,0,1" BorderBrush="#E2E8F0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="🖥️  ChatAgenda" FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}" FontFamily="Segoe UI"/>
                    <TextBlock Text="Panel de Administración del Servidor" FontSize="11"
                               Foreground="{StaticResource TextSecondary}" Margin="0,2,0,0" FontFamily="Segoe UI"/>
                </StackPanel>

                <!-- Indicador de estado -->
                <Border Grid.Column="1" CornerRadius="20" Padding="12,6" Background="#F1F5F9"
                        BorderThickness="1" BorderBrush="{StaticResource Border}"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse x:Name="StatusDot" Width="8" Height="8" Margin="0,0,7,0"
                                 Fill="{StaticResource AccentRed}" VerticalAlignment="Center">
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             From="1" To="0.3" Duration="0:0:1" AutoReverse="True"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                        <TextBlock x:Name="ServiceStatusLabel" Text="Detenido" FontSize="11"
                                   Foreground="{StaticResource TextSecondary}" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ═══════════════ CONTENT ═══════════════ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20,16,20,8" >

                <!-- ── Tarjeta: Estado del Servicio ── -->
                <Border Background="{StaticResource BgCard}" CornerRadius="12"
                        BorderThickness="1" BorderBrush="{StaticResource Border}" Padding="20,16" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Estado del Servicio" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondary}" FontFamily="Segoe UI" Margin="0,0,0,12"/>

                        <!-- Barra de estado detallada -->
                        <Border x:Name="ServiceStatusBar" CornerRadius="8" Padding="14,11"
                                Background="#F1F5F9" BorderThickness="1" BorderBrush="#E2E8F0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="ServiceStatusIcon" Text="⏸" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <StackPanel>
                                    <TextBlock x:Name="ServiceStatusTitle" Text="Servicio Detenido"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimary}" FontFamily="Segoe UI"/>
                                    <TextBlock x:Name="ServiceStatusDetail" Text="El servidor no está en ejecución"
                                               FontSize="11" Foreground="{StaticResource TextSecondary}" FontFamily="Segoe UI"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Controles del servicio -->
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button x:Name="BtnStartService" Grid.Column="0"
                                    Content="▶  Iniciar" Style="{StaticResource BtnSuccess}"
                                    Click="BtnStartService_Click" Height="38"/>
                            <Button x:Name="BtnStopService"  Grid.Column="2"
                                    Content="■  Detener" Style="{StaticResource BtnDanger}"
                                    Click="BtnStopService_Click" Height="38" IsEnabled="False"/>
                            <Button x:Name="BtnRestartService" Grid.Column="4"
                                    Content="↺  Reiniciar" Style="{StaticResource BtnPrimary}"
                                    Click="BtnRestartService_Click" Height="38" IsEnabled="False"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ── Tarjeta: Dirección de Conexión ── -->
                <Border Background="{StaticResource BgCard}" CornerRadius="12"
                        BorderThickness="1" BorderBrush="{StaticResource Border}" Padding="20,16" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Dirección para los Clientes" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondary}" FontFamily="Segoe UI" Margin="0,0,0,12"/>

                        <TextBlock Text="Comparte esta dirección con los clientes de la red:" FontSize="11"
                                   Foreground="{StaticResource TextSecondary}" FontFamily="Segoe UI" Margin="0,0,0,8"/>

                        <!-- IP principal -->
                        <Border CornerRadius="8" Padding="16,12" Margin="0,0,0,8"
                                Background="#F0FDF4" BorderThickness="1" BorderBrush="#22C55E30">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="🌐  Dirección principal" FontSize="10"
                                               Foreground="{StaticResource TextSecondary}" FontFamily="Segoe UI"/>
                                    <TextBlock x:Name="TxtMainIP" Text="Detectando..." FontSize="18"
                                               FontWeight="Bold" Foreground="#22C55E" FontFamily="Consolas" Margin="0,2,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="📋 Copiar" Style="{StaticResource BtnPrimary}"
                                        Click="BtnCopyIP_Click" Height="32" FontSize="11" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Todas las IPs -->
                        <TextBlock Text="Otras interfaces de red:" FontSize="10"
                                   Foreground="{StaticResource TextSecondary}" FontFamily="Segoe UI" Margin="0,4,0,4"/>
                        <ItemsControl x:Name="AllIPsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10,6" Margin="0,2" CornerRadius="6" Background="#F1F5F9">
                                        <TextBlock Text="{Binding}" FontSize="11" Foreground="{StaticResource TextSecondary}"
                                                   FontFamily="Consolas"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- ── Tarjeta: Acceso rápido ── -->
                <Border Background="{StaticResource BgCard}" CornerRadius="12"
                        BorderThickness="1" BorderBrush="{StaticResource Border}" Padding="20,16" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Acceso Rápido" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondary}" FontFamily="Segoe UI" Margin="0,0,0,12"/>

                        <Button Content="🌐  Abrir ChatAgenda en el navegador" Style="{StaticResource BtnPrimary}"
                                Click="BtnOpenBrowser_Click" Height="40" Margin="0,0,0,8"/>
                        <Button x:Name="BtnOpenWebView" Content="📱  Abrir interfaz integrada" Style="{StaticResource BtnPrimary}"
                                Click="BtnOpenWebView_Click" Height="40" Background="#7C3AED"/>
                    </StackPanel>
                </Border>

                <!-- ── Tarjeta: Configuración del Servicio ── -->
                <Border Background="{StaticResource BgCard}" CornerRadius="12"
                        BorderThickness="1" BorderBrush="{StaticResource Border}" Padding="20,16" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Configuración" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondary}" FontFamily="Segoe UI" Margin="0,0,0,12"/>

                        <CheckBox x:Name="ChkAutoStart" Content="  Iniciar servidor automáticamente con Windows"
                                  Foreground="{StaticResource TextPrimary}" FontFamily="Segoe UI" FontSize="12"
                                  Checked="ChkAutoStart_Checked" Unchecked="ChkAutoStart_Unchecked" Margin="0,0,0,8"/>

                        <Separator Background="{StaticResource Border}" Margin="0,8"/>

                        <Button Content="🗑️  Desinstalar Servicio de Windows" Style="{StaticResource BtnDanger}"
                                Click="BtnUninstallService_Click" Height="36" FontSize="12"/>
                    </StackPanel>
                </Border>

                <!-- ── Tarjeta: Log del servidor ── -->
                <Border Background="{StaticResource BgCard}" CornerRadius="12"
                        BorderThickness="1" BorderBrush="{StaticResource Border}" Padding="20,16" Margin="0,0,0,8">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Log del servidor" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondary}" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="Limpiar" Style="{StaticResource BtnPrimary}"
                                    Click="BtnClearLog_Click" Height="26" FontSize="10" Padding="10,4"
                                    Background="#E2E8F0" Foreground="#334155"/>
                        </Grid>

                        <Border Background="#F1F5F9" CornerRadius="6" Padding="12" Height="140">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" x:Name="LogScrollViewer">
                                <TextBlock x:Name="TxtLog" FontFamily="Consolas" FontSize="11"
                                           Foreground="#0F172A" TextWrapping="Wrap" LineHeight="18"/>
                            </ScrollViewer>
                        </Border>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ═══════════════ FOOTER ═══════════════ -->
        <Border Grid.Row="2" Background="#FFFFFF" Padding="20,10"
                BorderThickness="0,1,0,0" BorderBrush="{StaticResource Border}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TxtFooterStatus" Grid.Column="0"
                           Text="Iniciando..." FontSize="11" FontFamily="Segoe UI"
                           Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="Puerto: 5002" FontSize="11"
                           FontFamily="Segoe UI" Foreground="#475569" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
